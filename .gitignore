# C / C++ Compiled Outputs
# =========================
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exe
*.out
*.pdb
*.idb
*.ilk
*.exp
*.manifest

# =========================
# Runtime Data (Do Not Commit)
# =========================
/data/images/
/data/db/
/data/logs/

# Optional placeholder files if you use them
!/data/.gitkeep
!/data/images/.gitkeep
!/data/db/.gitkeep
!/data/logs/.gitkeep

