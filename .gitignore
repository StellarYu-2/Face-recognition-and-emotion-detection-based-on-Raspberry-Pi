# =========================
# CMake / Build Artifacts
# =========================
/build/
/build_rpi/
/cmake-build-*/
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
/install_manifest.txt
/Makefile
/build.ninja
/rules.ninja
/.ninja_*
/Testing/
/CTestTestfile.cmake
/compile_commands.json

