*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exe
*.out
*.pdb
*.idb
*.ilk
*.exp
*.manifest

# =========================
# Runtime Data (Do Not Commit)
# =========================
/data/images/
/data/db/
/data/logs/
/backups/
/cloud_server/data/
/platform_server/data/

# Optional placeholder files if you use them
!/data/.gitkeep
!/data/images/.gitkeep
!/data/db/.gitkeep
!/data/logs/.gitkeep

# =========================
# Model Weights / Large Files
# Keep converted NCNN files under models/onnx_to_ncnn trackable.
# =========================
/models/*.bin
/models/*.param
/models/**/*.onnx
/models/**/*.tflite
/models/**/*.pt
/models/**/*.pth
/models/**/*.ckpt
/models/**/*.engine
/models/**/*.weights
/models/**/*.zip
/models/buffalo_l/
/models/_build/

# =========================
